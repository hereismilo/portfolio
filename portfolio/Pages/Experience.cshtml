@page
@model ExperienceModel
@{ ViewData["Title"] = "Experience"; }
<style>
    .resume-section { max-width: 1000px; margin: 60px auto; font-family: 'Segoe UI', sans-serif; }
    .section-title { font-size: 2rem; font-weight: 800; color: #222; border-left: 5px solid #007bff; padding-left: 15px; }
    .cv-download-btn { display: inline-flex; align-items: center; padding: 10px 20px; background-color: #fff; color: #007bff; border: 2px solid #007bff; border-radius: 8px; text-decoration: none; font-weight: 700; transition: all 0.3s ease; }
    .cv-download-btn:hover { background-color: #007bff; color: #fff; transform: translateY(-2px); }
    .timeline { position: relative; padding-left: 30px; margin-top: 40px; }
    .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: #e9ecef; }
    .timeline-item { position: relative; margin-bottom: 50px; }
    .timeline-item::before { content: ''; position: absolute; left: -36px; top: 5px; width: 14px; height: 14px; border-radius: 50%; background: #007bff; border: 3px solid #fff; box-shadow: 0 0 0 3px #007bff; }
    .job-header { display: flex; justify-content: space-between; align-items: baseline; }
    .job-title { font-size: 1.25rem; font-weight: 700; color: #333; margin: 0; }
    .job-company { color: #007bff; font-weight: 600; }
    .job-date { font-size: 0.9rem; color: #777; font-weight: 600; background: #f8f9fa; padding: 4px 12px; border-radius: 20px; }
    .job-desc { list-style: none; padding: 0; margin: 15px 0 0 0; }
    .job-desc li { position: relative; padding-left: 20px; margin-bottom: 8px; color: #555; }
    .job-desc li::before { content: "→"; position: absolute; left: 0; color: #007bff; }
    .edu-card { background: #fff; border: 1px solid #eaeaea; border-radius: 12px; padding: 30px; margin-top: 20px; }
    .module-tag { display: inline-block; background: #eef6ff; color: #0056b3; padding: 4px 10px; border-radius: 4px; font-size: 0.85rem; margin: 4px; font-weight: 500; }
</style>

<div class="resume-section">
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap">
        <h2 class="section-title mb-0">Professional Experience</h2>
        <a href="/files/CV.pdf" download class="cv-download-btn">Download Full CV</a>
    </div>

    <div class="timeline">
        <div class="timeline-item">
            <div class="job-header">
                <div><h3 class="job-title">Graduate Software Engineer</h3><span class="job-company">Motorola Solutions (Avigilon Team)</span></div>
                <span class="job-date">2024 – Present</span>
            </div>
            <ul class="job-desc">
                <li>Architecting modular UI components in <strong>WPF</strong> using <strong>MVVM patterns</strong>.</li>
                <li>Managing real-time device discovery via <strong>ONVIF-compliant</strong> hardware integration.</li>
                <li>Integrating backend <strong>Tranquility APIs</strong> for video metadata processing.</li>
                <li>Delivering features within an <strong>Agile</strong> framework.</li>
            </ul>
        </div>
        <div class="timeline-item">
            <div class="job-header">
                <div><h3 class="job-title">Account Specialist II</h3><span class="job-company">Chase Bank</span></div>
                <span class="job-date">Jun 2025 – Present</span>
            </div>
            <ul class="job-desc">
                <li>Resolved 50+ complex queries daily under strict regulatory compliance.</li>
                <li>Reduced complaints by 12% by identifying recurring billing issues.</li>
            </ul>
        </div>
    </div>

    <h2 class="section-title" style="margin-top: 80px;">Education</h2>
    <div class="edu-card">
        <div class="job-header">
            <div><h3 class="job-title">MSc Software Engineering</h3><span class="job-company">Heriot-Watt University</span></div>
            <span class="job-date">2023 – 2024</span>
        </div>
        <p class="mt-3"><strong>Dissertation:</strong> Spam Review Detection for E-Commerce (Python). 86% Accuracy.</p>
        <div class="mt-2">
            <span class="module-tag">Industrial Programming</span>
            <span class="module-tag">Advanced Software Engineering</span>
            <span class="module-tag">Distributed & Parallel Technologies</span>
        </div>
    </div>
</div>