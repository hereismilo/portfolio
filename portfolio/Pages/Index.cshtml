@page
@model IndexModel
@{
    ViewData["Title"] = "Milo | Graduate Software Engineer";
}

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-blue: #007bff;
        --dark-text: #222;
        --light-text: #555;
    }

    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 50px;
        padding: 80px 20px;
        max-width: 1200px;
        margin: 0 auto;
        font-family: 'Poppins', sans-serif;
    }

    /* Content Styling */
    .hero-content {
        text-align: left;
    }

    .hero-content h1 {
        font-size: 1.1rem;
        color: var(--primary-blue);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .hero-content h2 {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--dark-text);
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .hero-content p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--light-text);
        margin-bottom: 35px;
    }

    .cta-button {
        display: inline-block;
        padding: 14px 35px;
        background-color: var(--primary-blue);
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
    }

    .cta-button:hover {
        background-color: #0056b3;
        transform: translateY(-2px);
        color: white;
    }

    /* Image & Flip Card Styling */
    .hero-image-wrapper {
        position: relative;
        perspective: 1500px;
        width: 100%;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 5; 
        transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
        cursor: pointer;
        z-index: 1;
    }

    .hero-image-wrapper.flipped .flip-card-inner {
        transform: rotateY(180deg);
    }

    .flip-front, .flip-back {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.15);
        overflow: hidden; 
    }

    .flip-back {
        transform: rotateY(180deg);
    }

    .hero-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
        display: block;
    }

    /* Handwritten Note Styling */
    .note-container {
        position: absolute;
        top: -70px;
        right: -60px;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        pointer-events: none;
    }

    .handwritten-text {
        font-family: 'Caveat', cursive;
        font-size: 1.6rem;
        color: var(--primary-blue);
        transform: rotate(-5deg);
        line-height: 1.2;
        text-align: center;
    }

    .pointer-arrow-svg {
        width: 80px;
        height: auto;
        margin-top: -10px;
    }

    .pointer-arrow-svg path {
        stroke: var(--primary-blue);
        stroke-width: 2.5;
        stroke-dasharray: 6 4;
        fill: none;
    }

    /* MOBILE RESPONSIVENESS */
    @@media (max-width: 992px) {
        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
            padding: 40px 20px;
            gap: 30px;
        }

        .hero-content {
            order: 2;
        }

        .hero-content h2 {
            font-size: 2.8rem;
        }

        .hero-image-wrapper {
            order: 1;
            max-width: 85%; /* Makes the image significantly larger on mobile */
            margin: 60px auto 20px auto;
        }

        .note-container {
            top: -85px;
            right: 0;
            left: 0; /* Center the note on mobile */
        }

        .handwritten-text {
            font-size: 1.4rem;
        }
    }

    @@media (max-width: 480px) {
        .hero-image-wrapper {
            max-width: 100%; 
        }
        .hero-content h2 {
            font-size: 2.2rem;
        }
    }
</style>

<div class="hero-container">
    <div class="hero-content">
        <h1>Welcome to my portfolio</h1>
        <h2>Hi! I'm Milo.</h2>
        <p>
            Graduated with a Master's degree in <strong>Computer Software Engineering</strong> from Heriot-Watt University. 
            Currently a Graduate Software Engineer at <strong>Motorola Solutions</strong> (Avigilon Team), 
            specializing in high-performance WPF architecture, ONVIF integrations, and TDD.
        </p>
        <div class="hero-actions">
            <a href="/Projects" class="cta-button">Explore My Work</a>
        </div>
    </div>

    <div class="hero-image-wrapper" id="imageWrapper">
        <div class="note-container">
            <div class="handwritten-text">all pictures have<br>two faces</div>
            <svg class="pointer-arrow-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <path d="M80,10 Q90,50 30,80" />
                <path d="M40,70 L30,80 L45,85" stroke-dasharray="0"/>
            </svg>
        </div>

        <div class="flip-card-inner" onclick="toggleFlip()">
            <div class="flip-front">
                <img src="/images/photo1.jpg" alt="Milo - Software Engineer" onerror="this.src='https://placehold.co/600x800?text=Milo+Front'"/>
            </div>
            <div class="flip-back">
                <img src="/images/photo2.jpg" alt="Milo - Software Engineer" onerror="this.src='https://placehold.co/600x800?text=Milo+Back'"/>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleFlip() {
        document.getElementById('imageWrapper').classList.toggle('flipped');
    }
</script>
