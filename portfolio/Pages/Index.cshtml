@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap" rel="stylesheet">
<style>
    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 50px;
        padding: 60px 20px;
        max-width: 1200px;
        margin: 0 auto;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .hero-content {
        text-align: left;
    }

    .hero-content h1 {
        font-size: 1.2rem;
        color: #007bff;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .hero-content h2 {
        font-size: 3.5rem;
        font-weight: 800;
        color: #222;
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .hero-content p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #555;
        margin-bottom: 30px;
    }

    .hero-image-wrapper {
        position: relative;
        perspective: 1000px;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 5; 
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
        cursor: pointer;
        z-index: 1;
    }

    .flipped .flip-card-inner {
        transform: rotateY(180deg);
    }

    .flip-front, .flip-back {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        overflow: hidden; 
    }

    .flip-back {
        transform: rotateY(180deg);
    }

    .hero-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
        display: block;
    }

    .note-container {
        position: absolute;
        top: -60px;
        right: -130px;
        width: 120px;
        height: auto;
        pointer-events: none;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .handwritten-text {
        font-family: 'Caveat', cursive;
        font-size: 1.5rem;
        color: #007bff;
        transform: rotate(-3deg);
        margin-bottom: 5px;
    }

    .pointer-arrow-svg {
        width: 100px;
        height: auto;
        transform: rotate(10deg);
    }

    .pointer-arrow-svg path {
        stroke: #007bff;
        stroke-width: 3;
        stroke-dasharray: 6 5;
        stroke-linecap: round;
        fill: none;
    }

    .cta-button {
        display: inline-block;
        padding: 12px 30px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        font-weight: 600;
        transition: background 0.2s;
    }

    .cta-button:hover {
        background-color: #0056b3;
        color: white;
    }

    @@media (max-width: 992px) {
        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
            padding: 40px 20px;
        }
        .hero-content {
            text-align: center;
            order: 2;
        }
        .hero-image-wrapper {
            order: 1;
            max-width: 500px;
            margin: 40px auto;
        }
        .note-container {
            position: relative;
            top: 0;
            right: 0;
            margin-bottom: 20px;
            width: auto;
        }
        .hero-content h2 {
            font-size: 2.5rem;
        }
    }
</style>

<div class="hero-container">
    <div class="hero-content">
        <h1>Welcome to my portfolio</h1>
        <h2>Hi! I'm Milo.</h2>
        <p>
            Graduated with a Master's degree in <strong>Computer Software Engineering</strong> from Heriot-Watt University. 
            Currently contributing to <strong>Motorola Solutions</strong> as a Graduate Software Engineer, 
            focusing on infrastructure, TDD, and scalable MS SQL solutions.
        </p>
        <div class="hero-actions">
            <a href="/Projects" class="cta-button">View My Work</a>
        </div>
    </div>

    <div class="hero-image-wrapper">
        <div class="note-container">
            <div class="handwritten-text">all pictures have<br>two faces</div>
            <svg class="pointer-arrow-svg" viewBox="0 0 100 150" xmlns="http://www.w3.org/2000/svg">
                <path d="M70,10 C 100,60, 10,100, 20,140" />
                <path d="M12,130 L20,140 L30,135" stroke-dasharray="0"/>
            </svg>
        </div>

        <div class="flip-card-inner" onclick="this.parentElement.classList.toggle('flipped')">
            <div class="flip-front">
                <img src="/images/photo1.jpg" alt="Milo - Front Face" />
            </div>
            <div class="flip-back">
                <img src="/images/photo2.jpg" alt="Milo - Second Face" />
            </div>
        </div>
    </div>
</div>