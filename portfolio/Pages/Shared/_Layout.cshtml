<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Milo's Portfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .custom-navbar {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
        }
        .navbar-brand { font-weight: 800; font-size: 1.4rem; color: #222 !important; }
        .navbar-brand span { color: #007bff; }

        .nav-link { 
            font-weight: 600; 
            color: #444 !important; 
            margin: 0 5px; 
            padding: 8px 15px !important;
            transition: all 0.3s ease; 
            position: relative;
            border-radius: 8px; 
        }

        .nav-link.active-link { 
            color: #fff !important;           
            background-color: #007bff;        
            box-shadow: 0 4px 10px rgba(0,123,255,0.2);
        }

        .nav-link:not(.active-link):hover { 
            color: #007bff !important; 
            background-color: rgba(0, 123, 255, 0.05);
        }
        .nav-btn { 
            background-color: #222; 
            color: white !important; 
            border-radius: 8px; 
            padding: 8px 20px !important; 
            margin-left: 15px; 
        }
        .nav-btn:hover { 
            background-color: #000; 
            transform: translateY(-1px); 
        }

        footer { background: #fdfdfd; padding: 40px 0; margin-top: 80px; border-top: 1px solid #eee; }
    </style>
</head>
<body>
    @{
        string IsActive(string page) => ViewContext.RouteData.Values["page"]?.ToString().ToLower() == page.ToLower() ? "active-link" : "";
    }

    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">MILO<span>.</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("/Index")" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsActive("/Projects")" asp-page="/Projects">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsActive("/Experience")" asp-page="/Experience">Experience</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsActive("/Skills")" asp-page="/Skills">Skills and Interests</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsActive("/Privacy")" asp-page="/Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-btn @IsActive("/Contact")" asp-page="/Contact">Contact Me</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-muted">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <strong>MILO.</strong>
                    <p class="small mb-0">&copy; 2026 - Software Engineer Portfolio</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a asp-page="/Privacy" class="text-muted text-decoration-none me-3">Privacy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>