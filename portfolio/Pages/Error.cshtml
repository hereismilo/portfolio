@page
@model ErrorModel
@{
    ViewData["Title"] = "Page Not Found";
}
<div style="text-align: center; padding: 100px 20px; font-family: 'Segoe UI', sans-serif;">
    <div style="font-size: 8rem; font-weight: 900; color: #f0f0f0; text-shadow: 2px 2px 0px #007bff;">404</div>
    <h1>Oops! You've drifted off course.</h1>
    <p>The page you are looking for doesn't exist. Let's get you back to familiar territory.</p>
    <div style="margin-top: 40px;">
        <a asp-page="/Index" style="padding: 12px 30px; background: #007bff; color: white; text-decoration: none; border-radius: 8px; font-weight: 600; margin-right: 15px;">Return Home</a>
        <a asp-page="/Contact" style="padding: 12px 30px; background: #f8f9fa; color: #333; text-decoration: none; border-radius: 8px; border: 1px solid #ddd; font-weight: 600;">Report Issue</a>
    </div>
</div>