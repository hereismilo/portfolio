            Timeline = "2023",
            ImageUrl = "/images/drilling-image.jpg",
            DescriptionPoints = new[]
            {
                "Built a complete .NET backend and Angular front-end architecture to track high-value drilling project milestones.",
                "Demonstrated strong initiative and structured problem-solving skills, taking ownership of the technical stack.",
                "Implemented secure REST APIs for seamless data synchronization between the UI and backend services."
            }
        },
        new
        {
            Id = "project2",
            Title = "Warehouse Management Application",
            TechStack = ".NET, Razor Pages, SQL",
            Timeline = "2024 (Self-Directed) / NISOC 2022",
            ImageUrl = "/images/warehouse-image.jpg",
            DescriptionPoints = new[]
            {
                "Designed and implemented a role-based access management system (RBAC) with secure CRUD functionality.",
                "Integrated robust SQL databases to handle real-time inventory and logistics tracking.",
                "Improved efficiency of store operations significantly by streamlining inventory audits and access controls."
            }
        },
        new
        {
            Id = "project3",
            Title = "Spam Review Detection",
